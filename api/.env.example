# Copier ce fichier en `.env` (non versionné) et adapter les valeurs à la machine.

# Connexion PostgreSQL (voir https://pris.ly/d/connection-strings).
DATABASE_URL="postgresql://postgres:1234@localhost:5433/esof_showroom?schema=public"

# Secret de signature des JWT (auth admin/commercial) — à changer en production.
JWT_SECRET="dev-only-secret-change-me-in-production"

# Origine(s) autorisée(s) en CORS pour l'admin (Vite), séparées par des virgules.
ADMIN_ORIGIN="http://localhost:5173"

# Port d'écoute de l'API (optionnel, 3000 par défaut).
# PORT=3000

# Dossier de stockage des images/vidéos uploadées (marques, catégories,
# sous-catégories, gammes, produits, vidéos promo). Optionnel : par défaut
# `./uploads` (relatif au dossier api/), mais ce dossier est gitignore — sur
# un poste donné, préférer un chemin absolu en dehors du dépôt pour ne pas
# perdre les fichiers lors d'un transfert du projet sur une autre machine.
# UPLOADS_ROOT="C:/Showroom/uploads"
