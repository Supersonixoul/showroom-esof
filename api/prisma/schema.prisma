// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Catalogue (v1) — proposition de schéma, à valider/ajuster avec ESOF.
// ---------------------------------------------------------------------------

model Brand {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  logoUrl   String?   @map("logo_url")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[]
  gammes    Gamme[]

  @@map("brands")
}

/// Ligne de produits d'une marque (ex. Legrand -> Céliane/Dooxie/Mosaic).
/// Toujours rattachée à une marque (relation obligatoire) ; toujours
/// facultative côté Product — voir Product.gammeId.
model Gamme {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String?
  imageUrl    String? @map("image_url")
  displayOrder Int    @default(0) @map("display_order")

  brandId String @map("brand_id") @db.Uuid
  brand   Brand  @relation(fields: [brandId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@unique([brandId, name])
  @@map("gammes")
}

model Category {
  id           String     @id @default(uuid()) @db.Uuid
  name         String
  imageUrl     String?    @map("image_url")
  isActive     Boolean    @default(true) @map("is_active")
  displayOrder Int        @default(0) @map("display_order")
  parentId     String?    @map("parent_id") @db.Uuid
  parent       Category?  @relation("CategoryToParent", fields: [parentId], references: [id])
  children     Category[] @relation("CategoryToParent")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[]
  subcategories Subcategory[]

  @@map("categories")
}

/// Affine la classification d'un produit au sein d'une catégorie
/// (ex. catégorie "Interrupteurs" -> sous-catégories "Simple", "Double"...).
/// Toujours facultative côté Product — voir Product.subcategoryId.
model Subcategory {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String?
  imageUrl    String? @map("image_url")
  displayOrder Int    @default(0) @map("display_order")

  categoryId String   @map("category_id") @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@unique([categoryId, name])
  @@map("subcategories")
}

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  reference    String?  @unique @db.VarChar(30)
  description  String?
  price        Decimal? @db.Decimal(12, 2)
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")

  /// Mise en avant (page d'accueil mobile/TV) — voir Partie A du brief
  /// "Marques statiques + Produits mis en avant".
  isNew       Boolean  @default(false) @map("is_new")
  onPromotion Boolean  @default(false) @map("on_promotion")
  promoPrice  Decimal? @map("promo_price") @db.Decimal(12, 2)
  onSale      Boolean  @default(false) @map("on_sale")
  salePrice   Decimal? @map("sale_price") @db.Decimal(12, 2)

  brandId    String?  @map("brand_id") @db.Uuid
  brand      Brand?   @relation(fields: [brandId], references: [id])
  categoryId String   @map("category_id") @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id])

  subcategoryId String?      @map("subcategory_id") @db.Uuid
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])

  gammeId String? @map("gamme_id") @db.Uuid
  gamme   Gamme?  @relation(fields: [gammeId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  specs      ProductSpec[]
  images     ProductImage[]
  quoteItems QuoteItem[]

  @@map("products")
}

/// Caractéristique technique libre (clé/valeur), ex. "Puissance" / "60W".
/// Sert aussi de source pour le menu de navigation "Caractéristiques".
model ProductSpec {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String
  value     String

  @@map("product_specs")
}

model ProductImage {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  position  Int     @default(0)

  @@map("product_images")
}

/// Vidéos publicitaires diffusées en boucle en mode ordinaire (app TV).
model PromoVideo {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  url       String
  position  Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("promo_videos")
}

// ---------------------------------------------------------------------------
// Comptes internes, clients, devis (v2)
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  COMMERCIAL
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role
  createdAt    DateTime @default(now()) @map("created_at")

  clientsCreated Client[]     @relation("ClientCreatedBy")
  clientNotes    ClientNote[]
  quotes         Quote[]

  @@map("users")
}

model Client {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  phone     String
  email     String?
  company   String?
  createdBy String   @map("created_by") @db.Uuid
  creator   User     @relation("ClientCreatedBy", fields: [createdBy], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  notes  ClientNote[]
  quotes Quote[]

  @@map("clients")
}

model ClientNote {
  id           String   @id @default(uuid()) @db.Uuid
  clientId     String   @map("client_id") @db.Uuid
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  commercialId String   @map("commercial_id") @db.Uuid
  commercial   User     @relation(fields: [commercialId], references: [id])
  note         String
  visitDate    DateTime @map("visit_date")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("client_notes")
}

enum QuoteStatus {
  DRAFT
  SENT
}

model Quote {
  id           String      @id @default(uuid()) @db.Uuid
  clientId     String      @map("client_id") @db.Uuid
  client       Client      @relation(fields: [clientId], references: [id])
  commercialId String      @map("commercial_id") @db.Uuid
  commercial   User        @relation(fields: [commercialId], references: [id])
  status       QuoteStatus @default(DRAFT)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  items QuoteItem[]

  @@map("quotes")
}

model QuoteItem {
  id        String  @id @default(uuid()) @db.Uuid
  quoteId   String  @map("quote_id") @db.Uuid
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)
  note      String?

  @@map("quote_items")
}
